#!/usr/bin/env bash
set -euo pipefail

# Connects to (or creates) a devcontainer for a git worktree.
# If the container is already running, execs a bash session into it.
# Otherwise creates a fresh container and launches Claude Code.
#
# Usage: dc-connect <repo_root> <branch> <issue>

source "$(dirname "$(readlink -f "$0")")/dc-lib"

REPO_ROOT="${1:?Usage: dc-connect <repo_root> <branch> <issue>}"
BRANCH="${2:?Missing branch}"
ISSUE="${3:?Missing issue}"

derive_names "$REPO_ROOT" "$BRANCH"

WORKTREE="$(dirname "$REPO_ROOT")/$BRANCH"

local_git_env_args=(
    -e "GIT_DIR=/git/worktrees/$BRANCH"
    -e "GIT_COMMON_DIR=/git"
)

STATE="$(docker container inspect -f '{{.State.Running}}' "$CONTAINER" 2>/dev/null || true)"

if [ "$STATE" = "true" ]; then
    exec docker exec -it \
        "${local_git_env_args[@]}" \
        "$CONTAINER" bash
elif [ -n "$STATE" ]; then
    docker rm "$CONTAINER" >/dev/null 2>&1 || true
fi

parse_devcontainer_json "$REPO_ROOT"
gather_credentials
generate_claude_seed "$BRANCH"

mount_args=()
for m in "${MOUNTS[@]+"${MOUNTS[@]}"}"; do
    mount_args+=(--mount "$m")
done

init_cmd="$(build_init_cmd "$ISSUE")"

if [ ! -d "$WORKTREE" ]; then
    echo "Error: worktree directory not found: $WORKTREE" >&2
    exit 1
fi

exec docker run -it --name "$CONTAINER" \
    --cap-add=NET_ADMIN \
    --cap-add=NET_RAW \
    -v "$WORKTREE:/workspace" \
    -v "$REPO_ROOT/.git:/git" \
    -v "$REPO_ROOT/.git/config:/git/config:ro" \
    -v "$REPO_ROOT/.devcontainer:/workspace/.devcontainer:ro" \
    "${token_args[@]+"${token_args[@]}"}" \
    "${local_git_env_args[@]}" \
    "${mount_args[@]+"${mount_args[@]}"}" \
    -w /workspace \
    "$DC_IMAGE" \
    bash -c "$init_cmd"

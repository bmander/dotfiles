#!/usr/bin/env bash
set -euo pipefail

# Opens a tmux window with Claude Code running inside a devcontainer for a
# fresh git worktree. Fails if a worktree for the issue already exists unless
# --use-old-worktree is passed.
#
# Usage: dispatchdc <issue-number> [--use-old-worktree] [--forward containerPort:hostPort ...]

source "$(dirname "$(readlink -f "$0")")/dc-lib"

USE_OLD_WORKTREE=0
ISSUE=""
FORWARD_ARGS=()
expect_forward=0
for arg in "$@"; do
    if [ "$expect_forward" -eq 1 ]; then
        FORWARD_ARGS+=(--forward "$arg")
        expect_forward=0
        continue
    fi
    case "$arg" in
        --use-old-worktree) USE_OLD_WORKTREE=1 ;;
        --forward) expect_forward=1 ;;
        *)
            if [ -n "$ISSUE" ]; then
                echo "Usage: dispatchdc <issue-number> [--use-old-worktree] [--forward containerPort:hostPort ...]" >&2
                exit 1
            fi
            ISSUE="$arg" ;;
    esac
done

if [ -z "$ISSUE" ]; then
    echo "Usage: dispatchdc <issue-number> [--use-old-worktree] [--forward containerPort:hostPort ...]"
    exit 1
fi

require_dispatch_prereqs

# Find or create worktree for this issue
WORKTREE="$(git worktree list | grep -E "/${ISSUE}-[^/]*$" | awk '{print $1}' || true)"

if [ -n "$WORKTREE" ]; then
    if [ "$USE_OLD_WORKTREE" -eq 0 ]; then
        echo "Error: worktree already exists at $WORKTREE" >&2
        echo "To reuse it, run: dispatchdc $ISSUE --use-old-worktree" >&2
        exit 1
    fi
else
    derive_branch_name "$ISSUE"
    WORKTREE="$(dirname "$REPO_ROOT")/$BRANCH"
    echo "Creating worktree for issue #$ISSUE..."
    git worktree add "$WORKTREE" -b "$BRANCH"
    if [ -f "$REPO_ROOT/.env" ]; then
        cp "$REPO_ROOT/.env" "$WORKTREE/.env"
        echo "Copied .env to worktree"
    fi
fi

BRANCH="$(basename "$WORKTREE")"

BIN="$(dirname "$(readlink -f "$0")")"
"$BIN/dc-build" "$REPO_ROOT"

FORWARD_STR=""
for fa in "${FORWARD_ARGS[@]+"${FORWARD_ARGS[@]}"}"; do
    FORWARD_STR="$FORWARD_STR $(printf '%q' "$fa")"
done

tmux new-window -n "${BRANCH:0:16}" \
    "CLAUDE_CODE_OAUTH_TOKEN=\"$CLAUDE_CODE_OAUTH_TOKEN\" \"$BIN/dc-connect\" \"$REPO_ROOT\" \"$BRANCH\" \"$ISSUE\"$FORWARD_STR || { echo '--- dc-connect failed (exit \$?) — press Enter to close ---'; read; }"

#!/usr/bin/env bash
set -euo pipefail

# Opens a tmux window with a shell inside the devcontainer for the current
# repo (or worktree). Builds the image and creates the container on first use.
#
# Usage: cd into any repo with a .devcontainer/Dockerfile, then run:
#   ~/devcontainer.sh

derive_names() {
    local workspace="$1"
    local slug
    slug="$(basename "$workspace" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-//;s/-$//')"
    IMAGE="devcontainer-${slug}"
    CONTAINER="devcontainer-${slug}"
}

parse_devcontainer_json() {
    local config="$1/.devcontainer/devcontainer.json"
    MOUNTS=()
    POST_CREATE=""
    if [ -f "$config" ] && command -v python3 &>/dev/null; then
        eval "$(python3 -c "
import json, re, shlex

with open('$config') as f:
    text = re.sub(r'//.*', '', f.read())
    cfg = json.loads(text)

mounts = cfg.get('mounts', [])
for i, m in enumerate(mounts):
    print(f'MOUNTS[{i}]={shlex.quote(m)}')

pc = cfg.get('postCreateCommand', '')
print(f'POST_CREATE={shlex.quote(pc)}')
" 2>/dev/null)"
    fi
}

do_connect() {
    local workspace="$1"
    derive_names "$workspace"
    parse_devcontainer_json "$workspace"

    local token_args=()
    if [ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
        token_args+=(-e "CLAUDE_CODE_OAUTH_TOKEN=$CLAUDE_CODE_OAUTH_TOKEN")
    fi

    local state
    state="$(docker container inspect -f '{{.State.Running}}' "$CONTAINER" 2>/dev/null || true)"
    if [ "$state" = "true" ]; then
        exec docker exec -it "${token_args[@]+"${token_args[@]}"}" "$CONTAINER" bash
    elif [ -n "$state" ]; then
        docker start "$CONTAINER" >/dev/null
        exec docker exec -it "${token_args[@]+"${token_args[@]}"}" "$CONTAINER" bash
    fi

    # First run — create the container
    local mount_args=()
    for m in "${MOUNTS[@]+"${MOUNTS[@]}"}"; do
        mount_args+=(--mount "$m")
    done

    local claude_seed
    claude_seed="$(python3 -c "
import json, sys
with open('$HOME/.claude.json') as f:
    d = json.load(f)
seed = {k: d[k] for k in ('oauthAccount','hasCompletedOnboarding','lastOnboardingVersion','installMethod','userID','opusProMigrationComplete','sonnet1m45MigrationComplete') if k in d}
seed['numStartups'] = 1
seed['projects'] = {'/workspace': {'allowedTools': [], 'mcpContextUris': [], 'mcpServers': {}, 'enabledMcpjsonServers': [], 'disabledMcpjsonServers': [], 'hasTrustDialogAccepted': True}}
print(json.dumps(seed))
")" || { echo "Error: failed to read $HOME/.claude.json — run claude once locally first" >&2; exit 1; }
    local init_cmd="echo $(printf '%q' "$claude_seed") > /root/.claude.json && mkdir -p /root/.claude && echo '{\"model\":\"claude-opus-4-6\"}' > /root/.claude/settings.json"
    if [ -n "$POST_CREATE" ]; then
        init_cmd="$init_cmd && echo '>>> Running postCreateCommand...' && $POST_CREATE"
    fi
    init_cmd="$init_cmd; exec bash"

    exec docker run -it --name "$CONTAINER" \
        -v "$workspace:/workspace" \
        "${token_args[@]+"${token_args[@]}"}" \
        "${mount_args[@]+"${mount_args[@]}"}" \
        -w /workspace \
        "$IMAGE" \
        bash -c "$init_cmd"
}

# --connect mode: called inside the tmux window
if [ "${1:-}" = "--connect" ]; then
    do_connect "${2:?Usage: dispatchdc --connect <workspace>}"
fi

# --- Main: resolve repo, build image, open tmux window ---

if [ -z "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]; then
    echo "Error: CLAUDE_CODE_OAUTH_TOKEN is not set." >&2
    echo "Run 'claude setup-token' to generate a token, then add to your shell profile:" >&2
    echo "  export CLAUDE_CODE_OAUTH_TOKEN=\"sk-ant-oat01-...\"" >&2
    exit 1
fi

WORKSPACE="$(git rev-parse --show-toplevel 2>/dev/null)" || {
    echo "Error: not inside a git repository" >&2
    exit 1
}

DOCKERFILE="$WORKSPACE/.devcontainer/Dockerfile"
if [ ! -f "$DOCKERFILE" ]; then
    echo "Error: no .devcontainer/Dockerfile in $WORKSPACE" >&2
    exit 1
fi

derive_names "$WORKSPACE"

# Compute hash of devcontainer config files to detect changes
HASH_FILES=()
for f in "$WORKSPACE/api/requirements.txt" "$WORKSPACE/api/requirements-dev.txt"; do
    [ -f "$f" ] && HASH_FILES+=("$f")
done
DEVCONTAINER_HASH="$({ find "$WORKSPACE/.devcontainer" -type f ! -name '*.dockerignore' -print0 | sort -z | xargs -0 cat; [ ${#HASH_FILES[@]} -gt 0 ] && cat "${HASH_FILES[@]}"; } | shasum -a 256 | cut -d' ' -f1)"
EXISTING_HASH="$(docker image inspect "$IMAGE" --format '{{index .Config.Labels "devcontainer.hash"}}' 2>/dev/null || true)"

if [ "$DEVCONTAINER_HASH" != "$EXISTING_HASH" ]; then
    echo "Building devcontainer image '$IMAGE'..."
    docker build -t "$IMAGE" --label "devcontainer.hash=$DEVCONTAINER_HASH" \
        -f "$DOCKERFILE" "$WORKSPACE"
    # Remove stale container so it gets recreated with the new image
    docker rm -f "$CONTAINER" 2>/dev/null || true
fi

# Resolve this script's absolute path for the tmux command
SCRIPT_PATH="$(cd "$(dirname "$0")" && pwd)/$(basename "$0")"

if [ -z "${TMUX:-}" ]; then
    echo "Error: not inside a tmux session" >&2
    exit 1
fi

tmux new-window -n "dev:$(basename "$WORKSPACE")" "CLAUDE_CODE_OAUTH_TOKEN=\"$CLAUDE_CODE_OAUTH_TOKEN\" \"$SCRIPT_PATH\" --connect \"$WORKSPACE\""
